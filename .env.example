# ==================== LLM (requerido) ====================
# Proveedor: openai (default) | azure | ollama
# LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
TEMPERATURE=0.7

# Azure OpenAI (solo si LLM_PROVIDER=azure)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-01

# Ollama local (solo si LLM_PROVIDER=ollama, sin API key)
# OLLAMA_MODEL=llama3

# ==================== LANGSMITH OBSERVABILIDAD (opcional) ====================
# Activa trazabilidad de todos los agentes y herramientas en https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-langsmith-key
# LANGCHAIN_PROJECT=multi-agents

# ==================== HITL (opcional) ====================
# Pide confirmación al usuario antes de ejecutar code_agent y web_scraping_agent
# Poner false en entornos batch o tests
# HITL_ENABLED=true

# ==================== PERSISTENCIA DE SESIONES ====================
# SQLite (default) — sessions/sessions.db, con migración one-shot desde JSONL
# Poner false para volver al backend JSONL original (sessions/{session_id}.jsonl)
# USE_SQLITE=true

# ==================== AGENTDOG GUARDRAIL (opcional) ====================
# URL del juez/guard (API OpenAI-compatible, ej. llama-server).
# Con docker compose up (juez en otro contenedor): usar host.docker.internal
# Con python main.py en el host: usar localhost
AGENTDOG_GUARD_URL=http://host.docker.internal:8080/v1/chat/completions
# AGENTDOG_API_KEY=
# AGENTDOG_POLICY=fail_open
# AGENTDOG_EVAL_MODE=high_risk_only
# AGENTDOG_AUDIT_LOG=./logs/agentdog_audit.jsonl
